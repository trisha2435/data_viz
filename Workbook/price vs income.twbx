      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.07z3b990i528k014gre2f12qk59p].[avg:MedianHomeValue:qk]&quot;' value='Home Price' />
          <alias key='&quot;[federated.07z3b990i528k014gre2f12qk59p].[avg:MedianHouseholdIncome:qk]&quot;' value='Income' />
        </aliases>
      </column>
      <column caption='Affordability Category' datatype='string' name='[AffordabilityCategory]' role='dimension' type='nominal' />
      <column caption='Home Price Index' datatype='real' name='[Calculation_0309840068927488]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([MedianHomeValue]) &#10;/ WINDOW_MIN(AVG([MedianHomeValue])) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Income Index' datatype='real' name='[Calculation_0309840069083137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([MedianHouseholdIncome]) &#10;/ WINDOW_MIN(AVG([MedianHouseholdIncome])) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Price to Income Ratio' datatype='real' name='[Calculation_0309840078831619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0309840078831619] &gt;= 7 THEN &quot;Severely Unaffordable&quot;&#10;ELSEIF [Calculation_0309840078831619] &gt;= 5 THEN &quot;Unaffordable&quot;&#10;ELSEIF [Calculation_0309840078831619] &gt;= 4 THEN &quot;Moderately Unaffordable&quot;&#10;ELSEIF [Calculation_0309840078831619] &gt;= 3.5 THEN &quot;Borderline&quot;&#10;ELSE &quot;Affordable&quot;&#10;END' />
      </column>
      <column caption='Price to Income Ratio FIXED' datatype='real' default-format='n#,##0.00&quot;x&quot;;-#,##0.00&quot;x&quot;' name='[Calculation_0309840080375813]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MedianHomeValue] / [MedianHouseholdIncome]' />
      </column>
      <column caption='Median Home Value' datatype='real' name='[MedianHomeValue]' role='measure' type='quantitative' />
